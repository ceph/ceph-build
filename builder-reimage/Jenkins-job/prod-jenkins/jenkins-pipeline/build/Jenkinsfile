pipeline {
    agent { label 'teuthology' }

    environment {
        DOMAIN = "front.sepia.ceph.com"
        VENV_DIR = ".venv"
    }

    parameters {
        booleanParam(name: 'SKIP_REIMAGE', defaultValue: false)
        choice(name: 'ACTION', choices: ['reimage','reimage-all','wait_online'])
        string(name: 'MACHINE', defaultValue: '', description: 'Comma-separated machines')
        string(name: 'OS', defaultValue: '')
    }

    stages {

        stage('Setup Python Virtual Environment') {
            steps {
                withCredentials([string(credentialsId: 'maas-api-key', variable: 'MAAS_API_KEY')]) {
                    sh '''
                        bash -c '
                        set -euo pipefail

                        REPO_DIR_LOCAL="${WORKSPACE}/builder-reimage/Jenkins-job/prod-jenkins"
                        VENV_PATH_LOCAL="${REPO_DIR_LOCAL}/.venv"

                        cd "$REPO_DIR_LOCAL"

                        rm -rf "$VENV_PATH_LOCAL"
                        python3 -m venv "$VENV_PATH_LOCAL"

                        source "$VENV_PATH_LOCAL/bin/activate"
                        pip install --upgrade pip
                        pip install -r requirements.txt
                        '
                    '''
                }
            }
        }

        stage('Parallel Execution') {
            steps {
                script {
                    if (!params.MACHINE?.trim()) {
                        error("MACHINE parameter is required")
                    }

                    def machines = params.MACHINE.split(',').collect { it.trim() }
                    def branches = [:]

                    for (int i = 0; i < machines.size(); i++) {
                        def machine = machines[i]

                        branches["Node-${machine}"] = {

                            node('teuthology') {

                                stage("Reimage-${machine}") {
                                    if (!params.SKIP_REIMAGE) {
                                        withCredentials([string(credentialsId: 'maas-api-key', variable: 'MAAS_API_KEY')]) {
                                            sh """
                                                bash -c '
                                                set -euo pipefail

                                                REPO_DIR_LOCAL="${WORKSPACE}/builder-reimage/Jenkins-job/prod-jenkins"
                                                VENV_PATH_LOCAL="${REPO_DIR_LOCAL}/.venv"

                                                cd "$REPO_DIR_LOCAL"
                                                source "$VENV_PATH_LOCAL/bin/activate"

                                                CMD="python Jenkins_builder-reimage.py \
                                                    --action reimage \
                                                    --machine ${machine} \
                                                    ${params.OS ? "--os ${params.OS}" : ""}"

                                                echo "Running: \$CMD"
                                                \$CMD
                                                '
                                            """
                                        }
                                    }
                                }

                                stage("Wait-${machine}") {
                                    if (!params.SKIP_REIMAGE) {
                                        withCredentials([string(credentialsId: 'maas-api-key', variable: 'MAAS_API_KEY')]) {
                                            sh """
                                                bash -c '
                                                set -euo pipefail

                                                REPO_DIR_LOCAL="${WORKSPACE}/builder-reimage/Jenkins-job/prod-jenkins"
                                                VENV_PATH_LOCAL="${REPO_DIR_LOCAL}/.venv"

                                                cd "$REPO_DIR_LOCAL"
                                                source "$VENV_PATH_LOCAL/bin/activate"

                                                python Jenkins_builder-reimage.py \
                                                    --action wait_online \
                                                    --machine ${machine}
                                                '
                                            """
                                        }
                                    }
                                }

                                stage("Ansible-${machine}") {
                                    withCredentials([
                                        string(credentialsId: 'builder-api-token', variable: 'BUILDER_TOKEN'),
                                        string(credentialsId: 'ansible-vault-pass', variable: 'VAULT_PASS'),
                                        sshUserPrivateKey(credentialsId: 'ansible-ssh-key', keyFileVariable: 'SSH_KEY')
                                    ]) {
                                        sh """
                                            bash -c '
                                            set -euo pipefail

                                            REPO_DIR_LOCAL="${WORKSPACE}/builder-reimage/Jenkins-job/prod-jenkins"
                                            BUILD_DIR="${REPO_DIR_LOCAL}/jenkins-pipeline/build"
                                            WORK_DIR_LOCAL="${WORKSPACE}/ci-work"

                                            TARGET_FQDN="${machine}.${DOMAIN}"
                                            echo "Processing \$TARGET_FQDN"

                                            mkdir -p "$WORK_DIR_LOCAL"

                                            cp "${SSH_KEY}" /tmp/key_${machine}
                                            chmod 600 /tmp/key_${machine}

                                            VAULT_FILE="/home/jenkins-build/.vault_pass.txt"
                                            echo "$VAULT_PASS" > "\$VAULT_FILE"

                                            cd "$BUILD_DIR"

                                            bash scripts/prepare_env.sh "${machine}.${DOMAIN}" "$WORK_DIR_LOCAL" true \
                                                git@github.com:ceph/ceph-build.git \
                                                git@github.com:ceph/ceph-cm-ansible.git \
                                                git@github.com:ceph/ceph-sepia-secrets.git

                                            DETECTED_OS="${params.OS ?: ''}"

                                            bash scripts/ansible_runner.sh \
                                                "\$TARGET_FQDN" \
                                                "$WORK_DIR_LOCAL" \
                                                "${VENV_DIR}" \
                                                "\$DETECTED_OS" \
                                                "\$BUILDER_TOKEN" \
                                                "\$VAULT_PASS"
                                            '
                                        """
                                    }
                                }
                            }
                        }
                    }

                    parallel branches
                }
            }
        }
    }

    post {
        always {
            sh 'rm -f /home/jenkins-build/.vault_pass.txt || true'
            echo 'Build finished!'
        }
    }
}
