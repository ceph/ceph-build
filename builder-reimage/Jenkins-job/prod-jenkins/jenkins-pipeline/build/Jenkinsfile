pipeline {
    agent any

    parameters {
        string(name: 'MACHINE', description: 'Comma separated nodes like node1,node2')
        string(name: 'WORK_DIR', defaultValue: '/home/jenkins-build/workspace')
        string(name: 'VENV_DIR', defaultValue: '.venv')
        string(name: 'BUILDER_TOKEN')
        booleanParam(name: 'SKIP_REIMAGE', defaultValue: false)
    }

    environment {
        BASE_WORK_DIR = "${WORK_DIR}"
    }

    stages {

        stage('Parallel Builder Execution') {
            steps {
                script {

                    if (!params.MACHINE?.trim()) {
                        error("MACHINE parameter is required")
                    }

                    def nodes = params.MACHINE.split(",")
                    def parallelStages = [:]

                    for (n in nodes) {

                        def nodeName = n.trim()

                        parallelStages[nodeName] = {

                            def NODE_WORK_DIR = "${BASE_WORK_DIR}/${nodeName}"

                            stage("Node ${nodeName}") {

                                echo "Processing ${nodeName}"

                                // Prepare environment and clone repositories
                                sh """
                                mkdir -p ${NODE_WORK_DIR}

                                builder-reimage/Jenkins-job/prod-jenkins/jenkins-pipeline/build/scripts/prepare_env.sh \
                                    ${nodeName} \
                                    ${NODE_WORK_DIR} \
                                    false
                                """

                                def INVENTORY_FILE = "${NODE_WORK_DIR}/repos/secret-repo/ansible/inventory/group_vars/jenkins_builders.yml"

                                // Update Jenkins labels from inventory
                                withCredentials([usernamePassword(
                                    credentialsId: 'jenkins-api-creds',
                                    usernameVariable: 'JENKINS_USER',
                                    passwordVariable: 'JENKINS_TOKEN'
                                )]) {

                                    sh """
                                    python3 scripts/sync_labels.py \
                                        --file ${INVENTORY_FILE} \
                                        --nodes ${nodeName} \
                                        --jenkins_url $JENKINS_URL \
                                        --user $JENKINS_USER \
                                        --token $JENKINS_TOKEN
                                    """
                                }

                                // Detect OS from installed os label
                                def DETECTED_OS = sh(
                                    script: """
                                    python3 scripts/get_node_os.py \
                                        ${INVENTORY_FILE} \
                                        ${nodeName}
                                    """,
                                    returnStdout: true
                                ).trim()

                                echo "Detected OS for ${nodeName} is ${DETECTED_OS}"

                                // Reimage using MaaS unless skipped
                                if (!params.SKIP_REIMAGE) {
                                    sh """
                                    python3 scripts/maas_deploy.py \
                                        --node ${nodeName} \
                                        --os ${DETECTED_OS}
                                    """
                                } else {
                                    echo "Reimage skipped for ${nodeName}"
                                }

                                // Run Ansible configuration
                                sh """
                                builder-reimage/Jenkins-job/prod-jenkins/jenkins-pipeline/build/scripts/ansible_runner.sh \
                                    ${nodeName} \
                                    ${NODE_WORK_DIR} \
                                    ${VENV_DIR} \
                                    ${DETECTED_OS} \
                                    ${BUILDER_TOKEN}
                                """

                                echo "Completed ${nodeName}"
                            }
                        }
                    }

                    parallel parallelStages
                }
            }
        }
    }

    post {
        always {
            echo "Archiving logs"
            archiveArtifacts artifacts: '**/ansible-logs/*.log', fingerprint: true
        }

        failure {
            echo "One or more nodes failed"
        }

        success {
            echo "All nodes completed successfully"
        }
    }
}
