pipeline {
    agent { label 'teuthology' }

    parameters {
        string(name: 'MACHINE', description: 'Comma separated nodes like node1,node2')
        string(name: 'WORK_DIR', defaultValue: '')
        string(name: 'VENV_DIR', defaultValue: '.venv')
        string(name: 'BUILDER_TOKEN')
        booleanParam(name: 'SKIP_REIMAGE', defaultValue: false)
    }

    stages {

        stage('Parallel Builder Execution') {
            steps {
                script {

                    if (!params.MACHINE?.trim()) {
                        error("MACHINE parameter is required")
                    }

                    def BASE_WORK_DIR = params.WORK_DIR?.trim() ? params.WORK_DIR : env.WORKSPACE
                    echo "Base work directory is ${BASE_WORK_DIR}"

                    def machines = params.MACHINE.split(',').collect { it.trim() }
                    def branches = [:]

                    for (int i = 0; i < machines.size(); i++) {
                        def machine = machines[i]

                        branches["Node-${machine}"] = {
                            node('teuthology') {

                                stage("Checkout-${machine}") {
                                    checkout scm
                                }

                                def NODE_WORK_DIR = "${BASE_WORK_DIR}/${machine}"

                                stage("Prepare-${machine}") {
                                    echo "Processing ${machine}"
                                    echo "Node work dir is ${NODE_WORK_DIR}"

                                    sh """
                                    mkdir -p ${NODE_WORK_DIR}

                                    bash builder-reimage/Jenkins-job/prod-jenkins/jenkins-pipeline/build/scripts/prepare_env.sh \
                                        ${machine} \
                                        ${NODE_WORK_DIR} \
                                        false
                                    """
                                }

                                def INVENTORY_FILE = "${NODE_WORK_DIR}/repos/secret-repo/ansible/inventory/group_vars/jenkins_builders.yml"

                                stage("Detect OS-${machine}") {
                                    def DETECTED_OS = sh(
                                        script: """
                                        python3 scripts/get_node_os.py \
                                            ${INVENTORY_FILE} \
                                            ${machine}
                                        """,
                                        returnStdout: true
                                    ).trim()

                                    env.DETECTED_OS = DETECTED_OS
                                    echo "Detected OS for ${machine} is ${DETECTED_OS}"
                                }

                                stage("Reimage-${machine}") {
                                    if (!params.SKIP_REIMAGE) {
                                        sh """
                                        python3 scripts/maas_deploy.py \
                                            --node ${machine} \
                                            --os ${env.DETECTED_OS}
                                        """
                                    } else {
                                        echo "Reimage skipped for ${machine}"
                                    }
                                }

                                stage("Ansible-${machine}") {
                                    withCredentials([
                                        string(credentialsId: 'builder-api-token', variable: 'BUILDER_TOKEN'),
                                        string(credentialsId: 'ansible-vault-pass', variable: 'VAULT_PASS'),
                                        sshUserPrivateKey(credentialsId: 'ansible-ssh-key', keyFileVariable: 'SSH_KEY')
                                    ]) {

                                        sh """
                                        TARGET_FQDN="${machine}"

                                        mkdir -p ${NODE_WORK_DIR}

                                        cp "${SSH_KEY}" /tmp/key_${machine}
                                        chmod 600 /tmp/key_${machine}

                                        VAULT_FILE="/home/jenkins-build/.vault_pass.txt"
                                        echo "$VAULT_PASS" > "$VAULT_FILE"

                                        bash builder-reimage/Jenkins-job/prod-jenkins/jenkins-pipeline/build/scripts/ansible_runner.sh \
                                            "$TARGET_FQDN" \
                                            "${NODE_WORK_DIR}" \
                                            "${VENV_DIR}" \
                                            "${env.DETECTED_OS}" \
                                            "$BUILDER_TOKEN"
                                        """
                                    }
                                }
                            }
                        }
                    }

                    branches.failFast = false
                    parallel branches
                }
            }
        }
    }

    post {
        always {
            sh 'rm -f /home/jenkins-build/.vault_pass.txt || true'
            echo 'Build finished'
            archiveArtifacts artifacts: '**/ansible-logs/*.log', fingerprint: true
        }

        failure {
            echo 'One or more nodes failed'
        }

        success {
            echo 'All nodes completed successfully'
        }
    }
}
