pipeline {
    agent { label 'teuthology' }

    environment {
        VENV_DIR = ".venv"
        DOMAIN   = "front.sepia.ceph.com"
    }

    parameters {
        booleanParam(name: 'SKIP_REIMAGE', defaultValue: false)

        choice(name: 'ACTION', choices: ['reimage','reimage-all','wait_online'])

        string(
            name: 'MACHINE',
            defaultValue: '',
            description: '''node1 OR
node1,node2 OR
node1:jammy,node2:centos9'''
        )

        string(
            name: 'OS',
            defaultValue: '',
            description: "Applies to all unless overridden by specifying OS per host in MACHINE. (optional)"
        )
    }

    stages {
        stage('Parallel Execution') {
            steps {
                script {

                    if (!params.MACHINE?.trim()) {
                        error("MACHINE parameter is required")
                    }

                    def machines = params.MACHINE.split(',').collect { it.trim() }
                    def branches = [:]

                    for (int i = 0; i < machines.size(); i++) {
                        def machine = machines[i]

                        branches["Node-${machine}"] = {
                            node('teuthology') {

                                stage("Checkout-${machine}") {
                                    checkout scm
                                }

                                stage("Reimage-${machine}") {
                                    if (!params.SKIP_REIMAGE) {
                                        withCredentials([string(credentialsId: 'maas-api-key', variable: 'MAAS_API_KEY')]) {

                                            sh """#!/bin/bash
set -euo pipefail

REPO_DIR="\$WORKSPACE/builder-reimage/Jenkins-job/prod-jenkins"
VENV_PATH="\$REPO_DIR/.venv"

cd "\$REPO_DIR"

if [ ! -d "\$VENV_PATH" ]; then
    echo "[INFO] Creating virtual environment"
    python3 -m venv "\$VENV_PATH"
    source "\$VENV_PATH/bin/activate"
    pip install --upgrade pip
    pip install -r requirements.txt
else
    source "\$VENV_PATH/bin/activate"
fi

echo "[INFO] Reimage ${machine}"

python Jenkins_builder-reimage.py \
  --action reimage \
  --machine ${machine} \
  ${params.OS ? "--os ${params.OS}" : ""}
"""
                                        }
                                    }
                                }

                                stage("Wait-${machine}") {
                                    if (!params.SKIP_REIMAGE) {
                                        withCredentials([string(credentialsId: 'maas-api-key', variable: 'MAAS_API_KEY')]) {

                                            sh """#!/bin/bash
set -euo pipefail

REPO_DIR="\$WORKSPACE/builder-reimage/Jenkins-job/prod-jenkins"
VENV_PATH="\$REPO_DIR/.venv"

cd "\$REPO_DIR"

if [ ! -d "\$VENV_PATH" ]; then
    python3 -m venv "\$VENV_PATH"
    source "\$VENV_PATH/bin/activate"
    pip install --upgrade pip
    pip install -r requirements.txt
else
    source "\$VENV_PATH/bin/activate"
fi

echo "[INFO] Waiting for ${machine}"

python Jenkins_builder-reimage.py \
  --action wait_online \
  --machine ${machine}
"""
                                        }
                                    }
                                }

                                stage("Ansible-${machine}") {

                                    withCredentials([
                                        string(credentialsId: 'builder-api-token', variable: 'BUILDER_TOKEN'),
                                        string(credentialsId: 'ansible-vault-pass', variable: 'VAULT_PASS'),
                                        sshUserPrivateKey(credentialsId: 'ansible-ssh-key', keyFileVariable: 'SSH_KEY')
                                    ]) {

                                        script {

                                            def playbooks = [
                                                "ansible_managed.yml",
                                                "users.yml",
                                                "jenkins-builder-disk.yml",
                                                "builder.yml"
                                            ]

                                            stage("Prepare-env-${machine}") {
                                                sh """#!/bin/bash
set -euo pipefail

REPO_DIR="\$WORKSPACE/builder-reimage/Jenkins-job/prod-jenkins"
BUILD_DIR="\$REPO_DIR/jenkins-pipeline/build"
WORK_DIR="\$WORKSPACE/ci-work"

mkdir -p "\$WORK_DIR"

cd "\$BUILD_DIR"

bash scripts/prepare_env.sh "${machine}.${DOMAIN}" "\$WORK_DIR" true \
  git@github.com:ceph/ceph-build.git \
  git@github.com:ceph/ceph-cm-ansible.git \
  git@github.com:ceph/ceph-sepia-secrets.git
"""
                                            }

                                            for (pb in playbooks) {

                                                stage("${pb}-${machine}") {

                                                    sh """#!/bin/bash
set -euo pipefail

REPO_DIR="\$WORKSPACE/builder-reimage/Jenkins-job/prod-jenkins"
BUILD_DIR="\$REPO_DIR/jenkins-pipeline/build"
WORK_DIR="\$WORKSPACE/ci-work"

TARGET_FQDN="${machine}.${DOMAIN}"

echo "[INFO] Running ${pb}"

cp "${SSH_KEY}" /tmp/key_${machine}
chmod 600 /tmp/key_${machine}

VAULT_FILE="/home/jenkins-build/.vault_pass.txt"
echo "$VAULT_PASS" > "\$VAULT_FILE"

cd "\$BUILD_DIR"

"\$WORK_DIR/.venv/bin/ansible-playbook" \
  -i inventory \
  --private-key /tmp/key_${machine} \
  --limit "\$TARGET_FQDN" \
  --extra-vars "builder_token=$BUILDER_TOKEN os=${params.OS ?: ''}" \
  -e "ansible_user=ubuntu" \
  --vault-password-file "\$VAULT_FILE" \
  playbooks/${pb}
"""
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                    branches.failFast = false
                    parallel branches
                }
            }
        }
    }

    post {
        always {
            sh 'rm -f /home/jenkins-build/.vault_pass.txt || true'
            echo 'Build finished!'
        }
    }
}
